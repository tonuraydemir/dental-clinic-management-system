// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url      = env("DATABASE_URL")
}

// 1. User Entity
model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  role         UserRole    @default(STAFF)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  visitNotes   VisitNote[] // Relationship: One user creates many visit notes
}

enum UserRole {
  MASTER
  STAFF
}

// 2. Patient Entity
model Patient {
  id               String          @id @default(cuid())
  fullName         String
  dateOfBirth      DateTime
  sex              String?
  address          String?
  phone            String?
  jmb              String          @unique
  employmentStatus String?
  occupation       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  anamnesis      Anamnesis?
  appointments   Appointment[]
  treatments     Treatment[]
  visitNotes     VisitNote[]
  treatmentPlans TreatmentPlan[]
  invoices       Invoice[]
}

// 3. Anamnesis Entity
model Anamnesis {
  id                      String   @id @default(cuid())
  patientId               String   @unique // One-to-one relationship
  patient                 Patient  @relation(fields: [patientId], references: [id])
  allergiesFlag           Boolean  @default(false)
  allergiesDetails        String?  @db.Text
  anesthesiaHistoryFlag   Boolean  @default(false)
  anesthesiaComplications String?  @db.Text
  medicationsFlag         Boolean  @default(false)
  medicationsDetails      String?  @db.Text
  previousDiseases        String?  @db.Text
  currentDisease          String?  @db.Text
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// 4. Appointment Entity
model Appointment {
  id        String            @id @default(cuid())
  patientId String
  patient   Patient           @relation(fields: [patientId], references: [id])
  startTime DateTime
  endTime   DateTime
  status    AppointmentStatus @default(SCHEDULED)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  visitNotes VisitNote[]
}

enum AppointmentStatus {
  SCHEDULED
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// 5. Treatment Entity
model Treatment {
  id            String          @id @default(cuid())
  patientId     String
  patient       Patient         @relation(fields: [patientId], references: [id])
  treatmentDate DateTime        @default(now())
  toothNumber   Int?
  diagnosis     String?
  therapy       String
  code          String
  status        TreatmentStatus @default(PLANNED)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  invoiceItems  InvoiceItem[]
}

enum TreatmentStatus {
  PLANNED
  COMPLETED
  INVOICED
}

// 6. VisitNote Entity
model VisitNote {
  id            String       @id @default(cuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  content       String       @db.Text
  noteDate      DateTime     @default(now())
  createdAt     DateTime     @default(now())
  
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  
  userId        String
  user          User         @relation(fields: [userId], references: [id])
}

// 7. TreatmentPlan Entity
model TreatmentPlan {
  id          String              @id @default(cuid())
  patientId   String
  patient     Patient             @relation(fields: [patientId], references: [id])
  title       String
  description String?             @db.Text
  status      TreatmentPlanStatus @default(OPEN)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  items       TreatmentPlanItem[]
}

enum TreatmentPlanStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// 8. TreatmentPlanItem Entity
model TreatmentPlanItem {
  id                   String                  @id @default(cuid())
  planId               String
  plan                 TreatmentPlan           @relation(fields: [planId], references: [id])
  plannedToothNumber   Int?
  plannedProcedureCode String
  plannedTherapy       String
  status               TreatmentPlanItemStatus @default(PLANNED)
}

enum TreatmentPlanItemStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

// 9. Invoice Entity
model Invoice {
  id            String        @id @default(cuid())
  patientId     String
  patient       Patient       @relation(fields: [patientId], references: [id])
  invoiceNumber String        @unique
  totalAmount   Float
  status        InvoiceStatus @default(DRAFT)
  createdAt     DateTime      @default(now())

  items         InvoiceItem[]
}

enum InvoiceStatus {
  DRAFT
  LOCKED
}

// 10. InvoiceItem Entity
model InvoiceItem {
  id            String    @id @default(cuid())
  invoiceId     String
  invoice       Invoice   @relation(fields: [invoiceId], references: [id])
  treatmentId   String
  treatment     Treatment @relation(fields: [treatmentId], references: [id])
  priceSnapshot Float
}

// 11. PriceListItem Entity
model PriceListItem {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  price     Float
  createdAt DateTime @default(now())
}