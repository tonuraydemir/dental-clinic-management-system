generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  role         UserRole    @default(STAFF)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  visitNotes   VisitNote[]
}

model Patient {
  id                 String              @id @default(cuid())
  fullName           String
  dateOfBirth        DateTime
  sex                String?
  address            String?
  phone              String?
  jmb                String              @unique
  employmentStatus   String?
  occupation         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  email              String?
  notes              String?
  anamnesis          Anamnesis?
  appointments       Appointment[]
  invoices           Invoice[]
  treatments         Treatment[]
  treatmentPlans     TreatmentPlan[]
  visitNotes         VisitNote[]
  odontogramSurfaces OdontogramSurface[]
}

model Anamnesis {
  id                      String   @id @default(cuid())
  patientId               String   @unique
  allergiesFlag           Boolean  @default(false)
  allergiesDetails        String?
  anesthesiaHistoryFlag   Boolean  @default(false)
  anesthesiaComplications String?
  medicationsFlag         Boolean  @default(false)
  medicationsDetails      String?
  previousDiseases        String?
  currentDisease          String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  patient                 Patient  @relation(fields: [patientId], references: [id])
}

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  startTime   DateTime
  endTime     DateTime
  status      AppointmentStatus @default(SCHEDULED)
  reason      String?           // İŞTE BURAYA EKLEDİK (Opsiyonel alan)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  patient     Patient           @relation(fields: [patientId], references: [id])
  visitNotes  VisitNote[]
}

model Treatment {
  id            String          @id @default(cuid())
  patientId     String
  treatmentDate DateTime        @default(now())
  toothNumber   Int?
  diagnosis     String?
  therapy       String
  code          String
  status        TreatmentStatus @default(PLANNED)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  invoiceItems  InvoiceItem[]
  patient       Patient         @relation(fields: [patientId], references: [id])
}

model VisitNote {
  id            String       @id @default(cuid())
  patientId     String
  content       String
  noteDate      DateTime     @default(now())
  createdAt     DateTime     @default(now())
  appointmentId String?
  userId        String
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  patient       Patient      @relation(fields: [patientId], references: [id])
  user          User         @relation(fields: [userId], references: [id])
}

model TreatmentPlan {
  id          String              @id @default(cuid())
  patientId   String
  title       String
  description String?
  status      TreatmentPlanStatus @default(OPEN)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  patient     Patient             @relation(fields: [patientId], references: [id])
  items       TreatmentPlanItem[]
}

model TreatmentPlanItem {
  id                   String                  @id @default(cuid())
  planId               String
  plannedToothNumber   Int?
  plannedProcedureCode String
  plannedTherapy       String
  status               TreatmentPlanItemStatus @default(PLANNED)
  plan                 TreatmentPlan           @relation(fields: [planId], references: [id])
}

model Invoice {
  id            String        @id @default(cuid())
  patientId     String
  invoiceNumber String        @unique
  subtotal      Float         @default(0)
  taxAmount     Float         @default(0)
  taxRate       Float         @default(0.17)
  totalAmount   Float
  status        InvoiceStatus @default(DRAFT)
  createdAt     DateTime      @default(now())
  patient       Patient       @relation(fields: [patientId], references: [id])
  items         InvoiceItem[]
}

model InvoiceItem {
  id              String    @id @default(cuid())
  invoiceId       String
  treatmentId     String?
  serviceCode     String
  serviceName     String
  quantity        Int       @default(1)
  unitPrice       Float
  totalPrice      Float
  invoice         Invoice   @relation(fields: [invoiceId], references: [id])
  treatment       Treatment? @relation(fields: [treatmentId], references: [id])
}

model PriceListItem {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  price     Float
  createdAt DateTime @default(now())
}

enum UserRole {
  MASTER
  STAFF
}

enum AppointmentStatus {
  SCHEDULED
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TreatmentStatus {
  PLANNED
  COMPLETED
  INVOICED
}

enum TreatmentPlanStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TreatmentPlanItemStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  PAID
  UNPAID
}

model OdontogramSurface {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  toothNumber Int
  surface     String
  condition   String
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([patientId, toothNumber, surface])
}
